# Munar Frontend Environment Variables
# Copy this file to .env.local and update values

# API Configuration
# For local dev with backend running on port 3000
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Feature Flags
# Set to 'false' to use the real Express + Neon DB backend
VITE_USE_MOCK_DATA=true
VITE_ENABLE_ANALYTICS=false
